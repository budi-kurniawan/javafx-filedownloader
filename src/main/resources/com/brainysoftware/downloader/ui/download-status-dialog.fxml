<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<GridPane xmlns:fx="http://javafx.com/fxml" 
		style="-fx-background-color: #ebfae7;"
		fx:controller="com.brainysoftware.downloader.ui.DownloadStatusDialogController" 
		hgap="10" vgap="10">
    <Label text="File:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
    <Label fx:id="pathLabel" GridPane.rowIndex="0" GridPane.columnIndex="1" />
    <Label text="Number of Pages:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
    <Label fx:id="numPagesLabel" GridPane.rowIndex="1" GridPane.columnIndex="1" />
    <Label text="Pages:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
	<HBox GridPane.rowIndex="2" GridPane.columnIndex="1">
        <fx:define>
			<ToggleGroup fx:id="pagesGroup" />
		</fx:define>

		<RadioButton text="All" toggleGroup="$pagesGroup" selected="true" onAction="#handleRadioButtonAction">
        	<HBox.margin>
		    	<Insets right="20.0"/>
			</HBox.margin>
		</RadioButton>
		<RadioButton text="Selection (e.g. 1-4,6,9-10)" toggleGroup="$pagesGroup" onAction="#handleRadioButtonAction">
        	<HBox.margin>
		    	<Insets right="20.0"/>
			</HBox.margin>
		</RadioButton>
		<TextField fx:id="pagesTextField" visible="false"/>
	</HBox>
</GridPane>